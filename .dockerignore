# 环境变量(含密钥,严禁打进镜像)
.env
.env.*
!.env.example

# 持久化数据 / 存储(运行时由 Render Disk 挂载,不进镜像)
data/
storage/
outputs/
uploads/

# Python 缓存 / 虚拟环境
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# 测试 / 类型检查缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE
.idea/
.vscode/

# Git(镜像内不需要版本库)
.git/

# 本地数据库文件
*.db
*.db-shm
*.db-wal
